{
  "data_configs": {
    "sgd": {
      "data_path": "./data/SGD",
      "n_samples": 5000,
      "scenario": 1
    }
  },
  "train_params": {
    "model_name": "nmmr_h",
    "loss_name": "U_statistic",
    "n_epochs": 150,
    "batch_size": 500,
    "patience": 30,
    "scheduler_patience": 15,
    "scheduler_factor": 0.5,
    "n_splits": 5,
    "log_metrics": "True",
    "network_depth": 4,
    "use_u_statistic": true,
    "kernel_gamma": 1.0,
    "hpo_n_trials":10,
    
    "learning_rate": {
        "type":"float",
        "low":8e-4,
        "high":2e-3,
        "log":true
    },
    "network_width": {
        "type":"categorical",
        "choices":[45, 50, 55]
    },
    "l2_penalty": {
        "type": "float",
        "low": 1e-6,
        "high": 5e-6,
        "log": true
    }
  }
}
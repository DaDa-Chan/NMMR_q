{
  "data_configs": {
    "sgd": {
      "data_path": "./data/SGD",
      "n_samples": 5000,
      "scenario": 1
    }
  },
  "train_params": {
    "model_name": "nmmr_q",
    "loss_name": "V_statistic",
    "n_epochs": 150,
    "batch_size": 500,
    "patience": 25,
    "scheduler_patience": 10,
    "scheduler_factor": 0.8,
    "n_splits": 5,
    "log_metrics": "True",
    "network_depth": 4,
    "use_u_statistic": false,
    "kernel_gamma": 0.6,
    "hpo_n_trials":15,
    
    "learning_rate": {
        "type":"float",
        "low":5e-4,
        "high":9e-3,
        "log":true
    },
    "network_width": {
        "type":"categorical",
        "choices":[45, 50, 55]
    },
    "l2_penalty": {
        "type": "float",
        "low": 1e-6,
        "high": 6e-6,
        "log": true
    }
  }
}
{
  "data_configs": {
    "rhc": {
      "data_path": "./data/right_heart_catheterization",
      "use_all_X": true
    }
  },
  "train_params": {
    "model_name": "nmmr_q",
    "loss_name": "V_statistic",
    "n_epochs": 100,
    "batch_size": 200,
    "patience": 25,
    "scheduler_patience": 5,
    "scheduler_factor": 0.5,
    "n_splits": 5,
    "log_metrics": "True",
    "network_depth": 4,
    "use_u_statistic": false,
    "kernel_gamma": 1.0,
    "learning_rate": 0.001,
    "network_width": 50,
    "l2_penalty": 1e-6
  }
}

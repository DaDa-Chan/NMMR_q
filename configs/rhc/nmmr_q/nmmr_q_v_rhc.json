{
  "data_configs": {
    "rhc": {
      "data_path": "./data/right_heart_catheterization",
      "use_all_X": true
    }
  },
  "train_params": {
    "model_name": "nmmr_q",
    "loss_name": "V_statistic",
    "n_epochs": 150,
    "batch_size": 1000,
    "patience": 40,
    "scheduler_patience": 10,
    "scheduler_factor": 0.75,
    "n_splits": 4,
    "log_metrics": "True",
    "network_depth": 6,
    "use_u_statistic": false,
    "kernel_gamma": 1,
    "hpo_n_trials":5,
    
    "learning_rate": {
        "type":"float",
        "low":1e-4,
        "high":9e-3,
        "log":true
    },
    "network_width": {
        "type":"categorical",
        "choices":[45, 50, 55, 60]
    },
    "l2_penalty": {
        "type": "float",
        "low": 1e-5,
        "high": 9e-4,
        "log": true
    }
  }
}